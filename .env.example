# Copy this file to ".env.local" and fill in your own values.
# .env.local is gitignored and will never be committed.

# ===== Clerk (Authentication) =====
# Dashboard: https://dashboard.clerk.com  ->  your app  ->  API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_public_key_here
CLERK_SECRET_KEY=your-clerk-secret-key-here

# ===== Supabase (Database + File Storage) =====
# Dashboard: your Supabase project  ->  Settings  ->  API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key

# ===== Google AI (Gemini) — generates the video & lab blueprints =====
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-key

# ===== Inngest (Background job queue) =====
# Local dev: keep INNGEST_DEV=1 and run `npx inngest-cli@latest dev` in a second terminal.
# Production: remove INNGEST_DEV and set the two keys below (from https://app.inngest.com).
INNGEST_DEV=1
# INNGEST_EVENT_KEY=your-event-key
# INNGEST_SIGNING_KEY=your-signing-key
